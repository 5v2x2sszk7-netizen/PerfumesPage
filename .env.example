ADMIN_TOKEN=change-me
CUSTOMER_SESSION_SECRET=change-me-too
NEXT_PUBLIC_SITE_URL=https://malofragances.mx

# Persistencia local en servidor con disco
PERFIMES_ALLOW_FS_WRITE=1

# Recuperacion de contraseña por correo
RESEND_API_KEY=PEGA_AQUI_TU_RESEND_API_KEY
RESEND_FROM_EMAIL=MALO Fragances <no-reply@tu-dominio.com>

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=PEGA_AQUI_TU_ACCESS_TOKEN
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=PEGA_AQUI_TU_PUBLIC_KEY
MERCADO_PAGO_WEBHOOK_SECRET=PEGA_AQUI_TU_SECRET_DE_WEBHOOK

# PayPal
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=PEGA_AQUI_TU_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=PEGA_AQUI_TU_PAYPAL_CLIENT_SECRET
PAYPAL_BRAND_NAME=MALO Fragances
PAYPAL_WEBHOOK_ID=PEGA_AQUI_TU_PAYPAL_WEBHOOK_ID
